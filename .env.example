# GlucoAssist Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── CGM Data Source ──────────────────────────────────────────────────────────
# Choose ONE of the four CGM_SOURCE values below and fill in the matching vars.
#
# CGM_SOURCE=librelink_direct   ← recommended: no external containers required
# CGM_SOURCE=librelink_push     ← nightscout-librelink-up sidecar, no Nightscout/MongoDB
# CGM_SOURCE=librelink          ← poll a running nightscout-librelink-up instance
# CGM_SOURCE=nightscout         ← poll a running Nightscout instance

# ─── Option 1: Direct LibreView API (CGM_SOURCE=librelink_direct) ─────────────
# GlucoAssist connects directly to Abbott's LibreView API — no sidecar needed.
# Backfill is limited to the current sensor window (~8 h); history accumulates
# going forward once this source is active.
LIBRELINK_EMAIL=your-librelink-email@example.com
LIBRELINK_PASSWORD=your-librelink-password
LIBRELINK_REGION=EU   # EU, US, DE, AU, CA, AP, FR, JP, AE, EU2
LIBRELINK_TOKENSTORE=/data/librelink_tokens.json   # cached auth token (persistent volume)

# ─── Option 2: nightscout-librelink-up push receiver (CGM_SOURCE=librelink_push) ──
# Run nightscout-librelink-up as a sidecar (see docker-compose.yml).
# Set NIGHTSCOUT_URL=http://<glucoassist-host> in the sidecar so it pushes
# readings to GlucoAssist's /api/v1/entries endpoint instead of a real Nightscout.
# LibreView credentials live in the sidecar container, not here.
LINK_UP_USERNAME=your-librelink-email@example.com
LINK_UP_PASSWORD=your-librelink-password
LINK_UP_REGION=EU
LINK_UP_INTERVAL=5          # minutes between polls
LINK_UP_ALL_DATA=false      # set true on first run to import full sensor history

# ─── Option 3: nightscout-librelink-up polling (CGM_SOURCE=librelink) ─────────
LIBRELINK_URL=http://your-librelink-host:PORT
LIBRELINK_POLL_INTERVAL=300

# ─── Option 4: Nightscout (CGM_SOURCE=nightscout) ─────────────────────────────
NIGHTSCOUT_URL=http://your-nightscout-host:PORT
#
# NIGHTSCOUT_TOKEN is the raw API_SECRET you set when you deployed Nightscout.
# Leave blank if your instance has no authentication enabled.
NIGHTSCOUT_TOKEN=your-nightscout-api-secret

CGM_SOURCE=librelink_direct

# ─── Application ──────────────────────────────────────────────────────────────
APP_SECRET_KEY=change-me-to-a-long-random-string
# APP_ENV controls three behaviours:
#   logging  — development: DEBUG-level output; production: INFO-level only
#   CORS     — development: allow any origin (*); production: same-origin only (behind Nginx)
#   /api/health — echoes the value back as the "environment" field
# Use "production" for all deployed instances. Set "development" only when running
# the backend directly (outside Docker) and you need verbose logs or cross-origin requests.
APP_ENV=production

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_PATH=/data/glucoassist.db

# ─── Push receiver authentication ────────────────────────────────────────────
# When set, GlucoAssist requires an API-SECRET header matching this value on
# all /api/v1/entries requests (GET and POST).  Leave blank to allow open access
# (backwards-compatible default).  Set to the same value as the uploader's
# --nightscout-api-secret / NIGHTSCOUT_API_SECRET argument.
#PUSH_SECRET=your-push-secret

# ─── Ingest ───────────────────────────────────────────────────────────────────
INGEST_INTERVAL_SECONDS=300

# Historical backfill: how many days of history to import on first startup
# when the database is empty.  Set to 0 to disable.
BACKFILL_DAYS=90

# ─── Garmin Integration ───────────────────────────────────────────────────────
# Set GARMIN_ENABLED=true to activate automatic daily ingest of resting HR,
# weight, sleep hours, and stress level from Garmin Connect.
# Minimum poll interval is 1 hour regardless of the value set below.
GARMIN_ENABLED=false
GARMIN_USERNAME=your-garmin-email@example.com
GARMIN_PASSWORD=your-garmin-password
GARMIN_INGEST_INTERVAL_SECONDS=3600

# Directory where Garmin OAuth tokens are cached after the first successful
# login.  Subsequent ingest runs load tokens from here instead of hitting
# Garmin SSO, which avoids repeated authentication and supports accounts
# with MFA enabled.
#
# If your account has MFA/2FA, run the one-time token seeding script first:
#   docker exec -it glucoassist python /app/scripts/garmin_login.py
#
# The directory must be on a persistent volume (same volume as DATABASE_PATH).
GARMIN_TOKENSTORE=/data/garmin_tokens
