# GlucoAssist Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── CGM Data Source ──────────────────────────────────────────────────────────
# Option A: nightscout-librelink-up (preferred)
LIBRELINK_URL=http://your-librelink-host:PORT
LIBRELINK_POLL_INTERVAL=300

# Option B: Nightscout (fallback / alternative)
NIGHTSCOUT_URL=http://your-nightscout-host:PORT
#
# NIGHTSCOUT_TOKEN is the raw API_SECRET you set when you deployed Nightscout —
# the same value you passed as the API_SECRET environment variable to your
# Nightscout container.  It must be at least 12 characters.
#
# How to find it:
#   - Docker/Compose: look for API_SECRET in your Nightscout docker-compose.yml
#     or container environment (e.g. `docker inspect nightscout | grep API_SECRET`)
#   - Unraid: open the Nightscout container's settings in the Unraid UI → Variables
#   - Heroku/Render: Settings → Config Vars → API_SECRET
#
# GlucoAssist sends this value in the `API-SECRET` request header when polling
# the Nightscout /api/v1/entries.json endpoint.  Leave blank if your Nightscout
# instance has no authentication enabled (not recommended on a LAN).
NIGHTSCOUT_TOKEN=your-nightscout-api-secret

# Which source to use: "librelink" or "nightscout"
CGM_SOURCE=librelink

# ─── Application ──────────────────────────────────────────────────────────────
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_ENV=production   # development | production

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_PATH=/data/glucoassist.db

# ─── Ingest ───────────────────────────────────────────────────────────────────
INGEST_INTERVAL_SECONDS=300

# Historical backfill: how many days of history to import on first startup
# when the database is empty.  Set to 0 to disable.
BACKFILL_DAYS=90

# ─── Garmin Integration ───────────────────────────────────────────────────────
# Set GARMIN_ENABLED=true to activate automatic daily ingest of resting HR,
# weight, sleep hours, and stress level from Garmin Connect.
# Minimum poll interval is 1 hour regardless of the value set below.
GARMIN_ENABLED=false
GARMIN_USERNAME=your-garmin-email@example.com
GARMIN_PASSWORD=your-garmin-password
GARMIN_INGEST_INTERVAL_SECONDS=3600
