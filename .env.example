# GlucoSense Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── CGM Data Source ──────────────────────────────────────────────────────────
# Option A: nightscout-librelink-up (preferred)
LIBRELINK_URL=http://your-librelink-host:PORT
LIBRELINK_POLL_INTERVAL=300

# Option B: Nightscout (fallback / alternative)
NIGHTSCOUT_URL=http://your-nightscout-host:PORT
NIGHTSCOUT_TOKEN=your-nightscout-api-secret

# Which source to use: "librelink" or "nightscout"
CGM_SOURCE=librelink

# ─── Application ──────────────────────────────────────────────────────────────
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_ENV=production   # development | production

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_PATH=/data/glucosense.db

# ─── Ingest ───────────────────────────────────────────────────────────────────
INGEST_INTERVAL_SECONDS=300
